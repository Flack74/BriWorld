# Frontend Environment Variables

# API Configuration
# For local development with Vite proxy: use /api and /ws
# For production: use full URLs like https://api.yourdomain.com
VITE_API_URL=/api
VITE_WS_URL=/ws

# App Configuration
VITE_APP_NAME=BriWorld
VITE_APP_VERSION=2.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# Game Settings
VITE_MAX_PLAYERS_PER_ROOM=6
VITE_DEFAULT_ROUNDS=10
VITE_DEFAULT_TIMEOUT=15

# Audio Settings
VITE_ENABLE_BACKGROUND_MUSIC=true
VITE_ENABLE_SOUND_EFFECTS=true
