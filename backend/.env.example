# Backend Environment Variables

# Database (Neon PostgreSQL)
DB_HOST=neon_host
DB_PORT=5432
DB_USER=yourneondbowner
DB_PASSWORD=your-neon-password
DB_NAME=neondb
DB_SSL_MODE=require

# Server
PORT=8080
ENV=development

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars-long
JWT_EXPIRY=86400
REFRESH_TOKEN_EXPIRY=2592000

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://yourdomain.com

# Game Config
MAX_PLAYERS_PER_ROOM=6
ROUND_DURATION_SECONDS=15
ROUNDS_PER_GAME=10

# Redis (Upstash)
REDIS_ADDR=allowing-kid-35323.upstash.io:6379
REDIS_PASSWORD=your-upstash-token
REDIS_DB=0
REDIS_TLS=true

# SMTP (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-email@example.com
SMTP_PASSWORD=your-brevo-smtp-key

# Cloudinary (Avatar Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
